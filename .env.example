# =============================================================================
# Straylight — environment variables
# Copy to .env and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# scripts/dev_gemma.sh — llama-server launcher
# -----------------------------------------------------------------------------

# Absolute path to the .gguf model file for llama-server.
LLAMA_MODEL=/path/to/your/llama.cpp/models/your-model.gguf

# Path to the llama-server binary. Defaults to the value below if unset.
LLAMA_SERVER=/path/to/your/llama.cpp/build/bin/llama-server

# Port llama-server listens on. Default 8080. CASS_LLM_BASE_URL is set automatically.
# LLAMA_PORT=8080

# Seconds to wait for /health before giving up. Default 300.
# Large models (35B+) need 2-4 minutes to warm up.
# LLAMA_HEALTH_TIMEOUT=300

# Performance flags — tuned for RTX + hybrid MoE (~25 t/s on Qwen3-35B A3B Q3_K_XL).
# Uncomment and adjust for your hardware.
# LLAMA_GPU_LAYERS=99     # layers to offload to GPU
# LLAMA_CPU_MOE=31        # MoE expert layers kept on CPU
# LLAMA_CTX_SIZE=80128    # context window
# LLAMA_THREADS=3         # CPU inference threads
# LLAMA_BATCH=512         # logical batch size

# -----------------------------------------------------------------------------
# Voice service — LLM
# -----------------------------------------------------------------------------

# Base URL of the llama-server OpenAI-compatible HTTP endpoint.
CASS_LLM_BASE_URL=http://127.0.0.1:8080

# Model alias passed in every /v1/chat/completions request.
# Must match --alias flag used when starting llama-server (dev_gemma.sh uses "cass").
CASS_LLM_MODEL=qwen3-coder

# In-process nomic-embed model used by AgentProcessor for fast-path routing.
# If missing, the router falls back to skill heuristics.
# CASS_EMBED_MODEL_PATH=/absolute/path/to/nomic-embed-text-v1.5.f16.gguf

# JSONL corpus used for negative ("none") exemplar loading.
# Format: {"text":"...","label":"none"}
# CASS_EXEMPLARS_PATH=/absolute/path/to/exemplars.jsonl

# Fast-path classifier tuning.
# CASS_ROUTER_THRESHOLD=0.80
# CASS_ROUTER_MIN_GAP=0.05

# -----------------------------------------------------------------------------
# Voice service — TTS / audio assets
# (defaults point to models/tts/ relative to repo root — only set if overriding)
# -----------------------------------------------------------------------------

# TTS_PIPER_MODEL=/absolute/path/to/en_US-amy-medium.onnx
# CASS_ACK_SOUND_PATH=/absolute/path/to/ack.mp3
# CASS_ACK_PLAYER_BIN=ffplay
# CASS_BOT_AUDIO_DRAIN_MS=450

# Optional stable device pinning by substring match against sounddevice names.
# Use this when auto-selection drifts onto the wrong ALSA input/output.
# Examples from `python -c "import sounddevice as sd; print(sd.query_devices())"`:
# CASS_INPUT_DEVICE_NAME=Wireless Stereo Headset
# CASS_OUTPUT_DEVICE_NAME=Wireless Stereo Headset

# -----------------------------------------------------------------------------
# Voice service — STT (faster-whisper auto-downloads base.en on first run)
# -----------------------------------------------------------------------------

# WHISPER_MODEL=base.en
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# -----------------------------------------------------------------------------
# Voice service — wake word
# (defaults point to models/wake/ relative to repo root — only set if overriding)
# -----------------------------------------------------------------------------

# CASS_WAKE_MODEL_DIR=/absolute/path/to/models/wake
# WAKEWORD_MODEL_FILE=computer_v2.onnx
# OWW_MELSPEC_MODEL_FILE=melspectrogram.onnx
# OWW_EMBEDDING_MODEL_FILE=embedding_model.onnx
# CASS_WAKE_THRESHOLD=0.5
# CASS_WAKE_GUARD_SECONDS=1.5

# -----------------------------------------------------------------------------
# Voice service — general
# -----------------------------------------------------------------------------

# CASS_ASSISTANT_NAME=Cass
# CASS_SAMPLE_RATE=16000
# CASS_HISTORY_TOKENS=4096
# CASS_PROMPT_PATH=/absolute/path/to/cass_prompt.txt
